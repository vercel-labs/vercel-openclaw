# Auth mode: "admin-secret" (default) or "sign-in-with-vercel".
# Admin-secret auth auto-generates a secret stored in Upstash (zero config).
# VERCEL_AUTH_MODE=admin-secret

# Required for any deployed environment that will connect Slack, Telegram, or Discord.
# Without Upstash, queue state, channel credentials, session history, and sandbox
# metadata are lost on cold starts. Provision via Vercel Marketplace:
# https://vercel.com/marketplace/upstash-redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AI Gateway auth: deployed Vercel environments use OIDC automatically.
# AI_GATEWAY_API_KEY is an optional static fallback when OIDC is unavailable.
# For local dev without OIDC, set AI_GATEWAY_API_KEY directly.
# AI_GATEWAY_API_KEY=

# Optional public origin override. When unset, the app derives the origin from
# request headers or Vercel system environment variables.
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: if Vercel Deployment Protection is enabled at the project level,
# this secret is appended to all channel webhook URLs (Slack, Telegram, WhatsApp,
# Discord) so they can reach the app. The app auto-detects active protection at
# runtime and hard-blocks channel connections when protection is on but this
# secret is missing.
# VERCEL_AUTOMATION_BYPASS_SECRET=

# Required only when VERCEL_AUTH_MODE=sign-in-with-vercel
NEXT_PUBLIC_VERCEL_APP_CLIENT_ID=
VERCEL_APP_CLIENT_SECRET=
SESSION_SECRET=

# Optional locally. On Vercel the deployment contract warns when unset or
# unpinned. The runtime falls back to a pinned known-good version
# (currently openclaw@2026.4.12). Pin to an exact version like
# openclaw@1.2.3 for deterministic sandbox resumes.
# OPENCLAW_PACKAGE_SPEC=openclaw@1.2.3

# Optional. Namespace for Redis keys. On Vercel, auto-uses VERCEL_PROJECT_ID
# when unset. Falls back to 'openclaw-single' locally. Set explicitly to override.
# OPENCLAW_INSTANCE_ID=

# Sandbox vCPU count: 1, 2, 4, or 8. Defaults to 1.
# Higher values may speed up resume and bootstrap at increased cost.
# OPENCLAW_SANDBOX_VCPUS=1

# How long the sandbox stays alive after the last activity, in milliseconds.
# Valid range: 60000 (1 min) to 2700000 (45 min). Defaults to 1800000 (30 min).
# Heartbeat and touch-throttle intervals are derived proportionally.
# Note: existing running sandboxes cannot be shortened in place; the new value
# becomes exact on the next create or restore.
# OPENCLAW_SANDBOX_SLEEP_AFTER_MS=1800000

# ---------- Optional ----------

# Optional on Vercel. /api/cron/watchdog uses CRON_SECRET when set; otherwise it
# falls back to ADMIN_SECRET. Missing both CRON_SECRET and ADMIN_SECRET on Vercel
# is a deployment-contract failure. Set CRON_SECRET separately if you want
# independent rotation for cron authentication.
# CRON_SECRET=

# Alternative Upstash-compatible KV endpoint (used when UPSTASH_* vars are unset)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Override the base domain used for channel webhook URLs (Slack, Discord, Telegram).
# Falls back to the HTTP Host header when unset.
# NEXT_PUBLIC_BASE_DOMAIN=

# Legacy alias for NEXT_PUBLIC_BASE_DOMAIN.
# BASE_DOMAIN=

# Optional: pre-fill `npx sandbox connect` on the admin Terminal tab (team / project).
# NEXT_PUBLIC_SANDBOX_SCOPE=my-team
# NEXT_PUBLIC_SANDBOX_PROJECT=my-project

# ---------- Slack OAuth install (optional) ----------

# When all three are set, the admin panel offers a one-click "Install to Slack"
# OAuth flow instead of manual credential entry. Create the Slack app once
# from the manifest flow, then set these values.
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_SIGNING_SECRET=

# Note: Channel credentials (Slack bot token, Telegram bot token, Discord bot
# token / public key) are NOT environment variables. They are configured through
# the admin UI and stored in the metadata store (Upstash Redis).
# When Slack OAuth install is configured, the bot token is obtained automatically
# through the OAuth flow and the signing secret is read from the env var above.
